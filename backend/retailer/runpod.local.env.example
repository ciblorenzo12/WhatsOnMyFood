# Copy this file to runpod.local.env. The local file is ignored by Git.
# Leave GEMINI_API_KEY blank: deploy-runpod.ps1 will ask for it securely when needed.
# Basic SSH: your-pod-user@ssh.runpod.io
# Direct TCP SSH: root@YOUR-POD-IP with the mapped TCP port below.
RUNPOD_SSH_TARGET=your-pod-user@ssh.runpod.io
# RUNPOD_SSH_PORT=YOUR-MAPPED-TCP-PORT
RUNPOD_SSH_KEY_PATH=C:\Users\your-user\.ssh\id_ed25519
RUNPOD_PUBLIC_URL=https://YOUR-POD-ID-8000.proxy.runpod.net
PORT=8000
GEMINI_MODEL=gemini-3.1-pro-preview
# GEMINI_API_KEY=
# BITWISE_APP_TOKEN=
