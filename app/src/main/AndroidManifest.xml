<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-feature
        android:name="android.hardware.camera"
        android:required="true" />

    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <queries>
        <package android:name="com.walmart.android" />
        <package android:name="com.target.ui" />
        <package android:name="com.amazon.mShop.android.shopping" />
        <package android:name="com.kroger.mobile" />
        <package android:name="com.instacart.client" />
        <package android:name="com.publix.main" />
        <package android:name="com.instacart.client.publix" />
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <category android:name="android.intent.category.BROWSABLE" />
            <data android:scheme="https" />
        </intent>
    </queries>

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/app_logo_rounded"
        android:label="@string/app_name"
        android:roundIcon="@drawable/app_logo_rounded"
        android:supportsRtl="true"
        android:theme="@style/Theme.MyApplication"
        android:usesCleartextTraffic="${usesCleartextTraffic}"
        tools:targetApi="31">


        <meta-data
            android:name="com.google.android.gms.version"
            android:value="@integer/google_play_services_version" />

        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.MyApplication">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".SignInActivity"
            android:exported="false"
            android:theme="@style/Theme.MyApplication" />

        <activity
            android:name=".MainActivity"
            android:exported="false" />

        <activity
            android:name=".ScanBarcodeActivity"
            android:exported="false"
            android:label="@string/title_activity_scan_barcode"
            android:theme="@style/Theme.MyApplication" />

        <activity
            android:name=".ProductDetailsActivity"
            android:exported="false"
            android:theme="@style/Theme.MyApplication" />

        <activity
            android:name=".PantryActivity"
            android:exported="false" />

        <activity
            android:name=".PantryInsightsActivity"
            android:exported="false"
            android:theme="@style/Theme.MyApplication" />

        <activity
            android:name=".PantryArInsightsActivity"
            android:exported="false"
            android:theme="@style/Theme.MyApplication" />
            
        <activity
            android:name=".ProfileActivity"
            android:exported="false" />

        <activity
            android:name=".PrivacyPolicyActivity"
            android:exported="false"
            android:label="@string/privacy_policy"
            android:theme="@style/Theme.MyApplication" />

        <activity
            android:name=".SubscriptionActivity"
            android:exported="false"
            android:label="@string/bitwise_plus"
            android:theme="@style/Theme.MyApplication" />

        <activity
            android:name=".AddProductActivity"
            android:exported="false" />

        <activity
            android:name=".AdditiveDatabaseActivity"
            android:exported="false"
            android:label="@string/additive_database"
            android:theme="@style/Theme.MyApplication" />

        <activity
            android:name=".IngredientAnalysisActivity"
            android:exported="false"
            android:label="@string/ingredient_analysis"
            android:theme="@style/Theme.MyApplication" />

        <activity
            android:name=".SourceViewerActivity"
            android:exported="false"
            android:label="@string/source_viewer"
            android:theme="@style/Theme.MyApplication" />

        <activity
            android:name=".WebViewActivity"
            android:exported="false"
            android:label="@string/source_viewer"
            android:theme="@style/Theme.MyApplication" />

        <activity
            android:name=".retail.MarketplaceActivity"
            android:exported="false"
            android:label="@string/marketplace_comparison"
            android:theme="@style/Theme.MyApplication" />
    </application>

</manifest>
