<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/bottom_sheet"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bottom_sheet_background"
    app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

    <View
        android:id="@+id/drag_handle"
        android:layout_width="48dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:background="@drawable/glass_drag_handle" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/nested_scroll_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:id="@+id/details_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <ImageView
                android:id="@+id/product_image_view"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/glass_hero_gradient"
                android:padding="8dp"
                android:scaleType="centerInside" />

            <TextView
                android:id="@+id/product_name_text_view"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/product_brand_text_view"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/source_status_text_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="@drawable/glass_panel"
                android:lineSpacingExtra="2dp"
                android:padding="12dp"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:visibility="gone"
                tools:text="Fresh cached result." />

            <TextView
                android:id="@+id/ingredients_label"
                style="@style/TextAppearance.AppCompat.Title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ingredients" />

            <TextView
                android:id="@+id/ingredients_text_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/glass_panel"
                android:lineSpacingExtra="4dp"
                android:padding="16dp"
                android:textColor="@color/text_secondary"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/health_score_text_view"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <!-- Bitwise AI Card -->
            <FrameLayout
                android:id="@+id/ai_summary_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                android:visibility="gone">

                <com.ciblorenzo.whatsonmyfood.AiGlowView
                    android:id="@+id/ai_card_glow"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_margin="4dp" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/ai_summary_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="12dp"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#E7E5FF"
                    app:strokeWidth="1dp"
                    app:cardBackgroundColor="#FBFAFF">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <com.ciblorenzo.whatsonmyfood.BitwiseAiSpriteView
                                android:layout_width="64dp"
                                android:layout_height="64dp"
                                android:layout_marginEnd="8dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/bitwise_ai"
                                android:textColor="@color/colorPrimary"
                                android:textStyle="bold"
                                android:textSize="18sp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/ai_summary_text_view"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:textSize="16sp"
                            android:lineSpacingExtra="6dp"
                            android:textColor="@color/text_primary" />

                        <View
                            android:id="@+id/ai_sources_divider"
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="16dp"
                            android:background="#E0E0E0"
                            android:visibility="gone"
                            tools:visibility="visible"/>

                        <TextView
                            android:id="@+id/ai_sources_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="@string/scientific_sources"
                            android:textSize="10sp"
                            android:textColor="@color/colorPrimary"
                            android:textStyle="bold"
                            android:letterSpacing="0"
                            android:visibility="gone"
                            tools:visibility="visible"/>

                        <TextView
                            android:id="@+id/ai_sources_text_view"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textSize="13sp"
                            android:textColor="@color/text_secondary"
                            android:fontFamily="sans-serif-light"
                            android:visibility="gone"
                            tools:text="- FDA CFR 21\n- WHO Sugars Guideline"
                            tools:visibility="visible"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </FrameLayout>

            <HorizontalScrollView
                android:id="@+id/certificate_badges_scroll_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:clipToPadding="false"
                android:overScrollMode="never"
                android:scrollbars="none"
                android:visibility="gone"
                tools:visibility="visible">

                <LinearLayout
                    android:id="@+id/certificate_badges_container"
                    android:layout_width="wrap_content"
                    android:layout_height="92dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    tools:ignore="UselessParent" />
            </HorizontalScrollView>

            <!-- Scores Section -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/scores_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/nutriscore_text_view"
                    style="@style/ScoreTextView"
                    android:background="@drawable/score_background"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@+id/nova_text_view"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/nova_text_view"
                    style="@style/ScoreTextView"
                    android:background="@drawable/score_background"
                    app:layout_constraintStart_toEndOf="@+id/nutriscore_text_view"
                    app:layout_constraintEnd_toStartOf="@+id/ecoscore_text_view"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/ecoscore_text_view"
                    style="@style/ScoreTextView"
                    android:background="@drawable/score_background"
                    app:layout_constraintStart_toEndOf="@+id/nova_text_view"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <include layout="@layout/layout_retailer_commerce" />

            <!-- Analysis Results -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/analysis_recycler_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/serving_size_label"
                style="@style/TextAppearance.AppCompat.Title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/serving_size" />

            <TextView
                android:id="@+id/serving_size_text_view"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp" />

            <!-- Nutrition Facts Table -->
            <TextView
                style="@style/TextAppearance.AppCompat.Title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/nutrition_facts" />

            <TableLayout
                android:id="@+id/nutrition_facts_table"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/categories_label"
                style="@style/TextAppearance.AppCompat.Title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/categories" />

            <TextView
                android:id="@+id/categories_text_view"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/packaging_label"
                style="@style/TextAppearance.AppCompat.Title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/packaging" />

            <TextView
                android:id="@+id/packaging_text_view"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/labels_label"
                style="@style/TextAppearance.AppCompat.Title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/labels_certifications_awards" />

            <TextView
                android:id="@+id/labels_text_view"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp" />

            <Button
                android:id="@+id/update_product_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="24dp"
                android:text="@string/update_product" />

            <Button
                android:id="@+id/contribute_ingredients_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="12dp"
                android:text="@string/off_add_missing_ingredients"
                android:visibility="gone" />
            
            <Button
                android:id="@+id/remove_from_pantry_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="12dp"
                android:text="@string/remove_from_pantry"
                android:visibility="gone" />
        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <include layout="@layout/layout_loading_overlay" />

</LinearLayout>
