<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="300dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="12dp"
    app:cardBackgroundColor="@color/glass_panel"
    app:cardCornerRadius="18dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/glass_stroke"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/glass_panel"
        android:minHeight="286dp"
        android:orientation="vertical"
        android:padding="14dp">

        <FrameLayout
            android:id="@+id/alternative_thumbnail_frame"
            android:layout_width="match_parent"
            android:layout_height="108dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/alternative_thumb_background"
            android:padding="8dp">

            <ImageView
                android:id="@+id/alternative_image_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:adjustViewBounds="true"
                android:scaleType="centerInside"
                android:visibility="gone"
                tools:visibility="visible" />

            <LinearLayout
                android:id="@+id/alternative_placeholder_layout"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                tools:visibility="gone">

                <TextView
                    android:id="@+id/alternative_placeholder_initials_text_view"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:background="@drawable/alternative_health_chip_background"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:textColor="#057A45"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    tools:text="RX" />

                <TextView
                    android:id="@+id/alternative_placeholder_label_text_view"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:maxLines="1"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    tools:text="Protein Bar" />
            </LinearLayout>
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/alternative_signal_text_view"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/alternative_health_chip_background"
                android:paddingStart="8dp"
                android:paddingTop="3dp"
                android:paddingEnd="8dp"
                android:paddingBottom="3dp"
                android:textColor="#057A45"
                android:textSize="11sp"
                android:textStyle="bold"
                tools:text="Healthy option" />

            <TextView
                android:id="@+id/alternative_category_text_view"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:background="@drawable/alternative_category_chip_background"
                android:paddingStart="8dp"
                android:paddingTop="3dp"
                android:paddingEnd="8dp"
                android:paddingBottom="3dp"
                android:textColor="#5B21B6"
                android:textSize="11sp"
                android:textStyle="bold"
                tools:text="Same type" />
        </LinearLayout>

        <TextView
            android:id="@+id/alternative_name_text_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            tools:text="No Added Sugar Protein Bar" />

        <TextView
            android:id="@+id/alternative_brand_text_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            tools:text="RXBAR" />

        <TextView
            android:id="@+id/alternative_reason_text_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:lineSpacingExtra="2dp"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            tools:text="Simple formula with protein-forward ingredients." />

        <TextView
            android:id="@+id/alternative_retailer_hint_text_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/text_muted"
            android:textSize="12sp"
            tools:text="Available online and near many grocery stores" />

        <Button
            android:id="@+id/alternative_view_button"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:text="@string/view_product"
            app:cornerRadius="14dp" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
