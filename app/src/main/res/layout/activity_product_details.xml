<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@drawable/glass_activity_background"
    tools:context=".ProductDetailsActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar_layout"
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:background="@drawable/glass_hero_gradient"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        app:elevation="0dp">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:id="@+id/collapsing_toolbar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:contentScrim="@color/colorPrimary"
            app:layout_scrollFlags="scroll|exitUntilCollapsed|snap">

            <ImageView
                android:id="@+id/product_image_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/glass_hero_gradient"
                android:scaleType="centerInside"
                app:layout_collapseMode="parallax" />

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/product_details_toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                app:layout_collapseMode="pin" />

        </com.google.android.material.appbar.CollapsingToolbarLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/nested_scroll_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="-24dp"
        android:background="@drawable/rounded_top_surface"
        android:paddingTop="24dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:id="@+id/details_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/product_name_text_view"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:textColor="@color/text_primary"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/product_brand_text_view"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="16sp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/source_status_text_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="@drawable/glass_panel"
                android:lineSpacingExtra="2dp"
                android:padding="12dp"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:visibility="gone"
                tools:text="Fresh cached result." />

            <TextView
                android:id="@+id/health_score_text_view"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/colorPrimary"
                android:layout_marginBottom="16dp"
                tools:text="Healthy"/>

            <!-- Bitwise AI Insight Card -->
            <FrameLayout
                android:id="@+id/ai_summary_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:visibility="gone"
                tools:visibility="visible">

                <com.ciblorenzo.whatsonmyfood.AiGlowView
                    android:id="@+id/ai_card_glow"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_margin="4dp" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/ai_summary_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="12dp"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#E7E5FF"
                    app:strokeWidth="1dp"
                    app:cardBackgroundColor="#FBFAFF">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <com.ciblorenzo.whatsonmyfood.BitwiseAiSpriteView
                                android:layout_width="64dp"
                                android:layout_height="64dp"
                                android:layout_marginEnd="8dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/bitwise_ai"
                                android:textColor="@color/colorPrimary"
                                android:textStyle="bold"
                                android:textSize="18sp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/ai_summary_text_view"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:textSize="16sp"
                            android:lineSpacingExtra="6dp"
                            android:textColor="@color/text_primary"
                            tools:text="Bitwise AI is analyzing..."/>

                        <View
                            android:id="@+id/ai_sources_divider"
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="16dp"
                            android:background="#E0E0E0"
                            android:visibility="gone"
                            tools:visibility="visible"/>

                        <TextView
                            android:id="@+id/ai_sources_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="@string/scientific_sources"
                            android:textSize="10sp"
                            android:textColor="@color/colorPrimary"
                            android:textStyle="bold"
                            android:letterSpacing="0"
                            android:visibility="gone"
                            tools:visibility="visible"/>

                        <TextView
                            android:id="@+id/ai_sources_text_view"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textSize="13sp"
                            android:textColor="@color/text_secondary"
                            android:fontFamily="sans-serif-light"
                            android:visibility="gone"
                            tools:text="- FDA CFR 21\n- WHO Sugars Guideline"
                            tools:visibility="visible"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </FrameLayout>

            <HorizontalScrollView
                android:id="@+id/certificate_badges_scroll_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:clipToPadding="false"
                android:overScrollMode="never"
                android:scrollbars="none"
                android:visibility="gone"
                tools:visibility="visible">

                <LinearLayout
                    android:id="@+id/certificate_badges_container"
                    android:layout_width="wrap_content"
                    android:layout_height="92dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    tools:ignore="UselessParent" />
            </HorizontalScrollView>

            <!-- Scores Section -->
            <LinearLayout
                android:id="@+id/scores_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/nutriscore_text_view"
                    style="@style/ScoreTextView"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Nutri-Score" />

                <TextView
                    android:id="@+id/nova_text_view"
                    style="@style/ScoreTextView"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="NOVA" />

                <TextView
                    android:id="@+id/ecoscore_text_view"
                    style="@style/ScoreTextView"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Eco-Score" />
            </LinearLayout>

            <TextView
                android:id="@+id/ingredients_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ingredients"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:textSize="18sp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/ingredients_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/glass_panel"
                app:cardCornerRadius="22dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/glass_stroke"
                app:strokeWidth="1dp">
                <TextView
                    android:id="@+id/ingredients_text_view"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/glass_panel"
                    android:padding="16dp"
                    android:textSize="15sp"
                    android:lineSpacingExtra="4dp"
                    android:textColor="@color/text_secondary"
                    tools:text="Water, Sugar, Corn Syrup..." />
            </com.google.android.material.card.MaterialCardView>

            <include layout="@layout/layout_retailer_commerce" />

            <!-- Analysis Results -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/analysis_recycler_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/serving_size_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                    android:text="@string/serving_size"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/serving_size_text_view"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="24dp" />

            <!-- Nutrition Facts Table -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nutrition_facts"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="12dp" />

            <TableLayout
                android:id="@+id/nutrition_facts_table"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp" />

            <TextView
                android:id="@+id/categories_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/categories"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/categories_text_view"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/packaging_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/packaging"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/packaging_text_view"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/labels_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/labels_certifications_awards"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/labels_text_view"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="16dp" />

            <Button
                android:id="@+id/update_product_button"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="24dp"
                android:text="@string/update_product"
                app:cornerRadius="16dp" />

            <Button
                android:id="@+id/contribute_ingredients_button"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="12dp"
                android:text="@string/off_add_missing_ingredients"
                android:visibility="gone"
                app:cornerRadius="16dp" />

            <Button
                android:id="@+id/remove_from_pantry_button"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="12dp"
                android:text="@string/remove_from_pantry"
                app:cornerRadius="16dp"
                android:visibility="gone" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <include layout="@layout/layout_loading_overlay" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
