<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="oval">
            <solid android:color="#B800E5FF" />
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <gradient
                android:angle="0"
                android:endColor="#B900E5FF"
                android:startColor="#D27C4DFF"
                android:type="linear" />
        </shape>
    </item>
</selector>
